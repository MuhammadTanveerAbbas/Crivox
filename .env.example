# ─── Supabase ────────────────────────────────────────────────────────────────

# Your Supabase project URL (found in Project Settings > API)
VITE_SUPABASE_URL=https://<your-project-id>.supabase.co

# Supabase anon/public key (safe to expose in frontend — RLS enforces permissions)
VITE_SUPABASE_PUBLISHABLE_KEY=<your-anon-key>

# Supabase project ID (used for direct API calls if needed)
VITE_SUPABASE_PROJECT_ID=<your-project-id>

# ─── Server-Only Secrets (set in Vercel/Supabase, NOT in VITE_) ─────────────

# Supabase URL (used in Vercel serverless functions like api/health.ts)
# This is the same value as VITE_SUPABASE_URL but accessible server-side
SUPABASE_URL=<your-supabase-url>

# Supabase anon key (used in Vercel serverless functions)
# This is the same value as VITE_SUPABASE_PUBLISHABLE_KEY but accessible server-side
SUPABASE_ANON_KEY=<your-anon-key>

# Supabase service role key (NEVER prefix with VITE_ — server/edge-functions only)
# Used only in Supabase Edge Functions and Vercel serverless functions.
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Groq API key — get it from https://console.groq.com/keys
# Set as a Supabase Edge Function secret: supabase secrets set GROQ_API_KEY=<key>
# Set as a Vercel environment variable for production.
GROQ_API_KEY=<your-groq-api-key>

# CRON secret for keep-alive endpoint (optional)
CRON_SECRET=<your-cron-secret>

# ─── Vite Dev Server-Only (optional) ──────────────────────────────────────────

# Vite dev server port (default: 8080)
VITE_DEV_PORT=8080
