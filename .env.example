# ─── Supabase ────────────────────────────────────────────────────────────────

# Your Supabase project URL (found in Project Settings > API)
VITE_SUPABASE_URL=https://<your-project-id>.supabase.co

# Supabase anon/public key (safe to expose in frontend; RLS enforces permissions)
VITE_SUPABASE_PUBLISHABLE_KEY=<your-anon-key>

# Supabase project ID (used for direct API calls if needed)
VITE_SUPABASE_PROJECT_ID=<your-project-id>

# ─── Server-Only Secrets (set in Vercel/Supabase, NOT in VITE_) ─────────────

# Supabase URL (used in Vercel serverless functions like api/health.ts)
# This is the same value as VITE_SUPABASE_URL but accessible server-side
SUPABASE_URL=<your-supabase-url>

# Supabase anon key (used in Vercel serverless functions)
# This is the same value as VITE_SUPABASE_PUBLISHABLE_KEY but accessible server-side
SUPABASE_ANON_KEY=<your-anon-key>

# Supabase service role key (NEVER prefix with VITE_; server/edge-functions only)
# Used only in Supabase Edge Functions and Vercel serverless functions.
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Groq API key — get it from https://console.groq.com/keys
# Set as a Supabase Edge Function secret: supabase secrets set GROQ_API_KEY=<key>
# Set as a Vercel environment variable for production.
GROQ_API_KEY=<your-groq-api-key>

# ─── AI Model Selection (optional — edge function env vars) ──────────────────
# These are read by supabase/functions/generate-comments/index.ts.
# If not set, the edge function uses the defaults below.
# You can change these ANYTIME via Supabase secrets — NO code redeploy needed.

# Primary text generation model (default: "llama-3.3-70b-versatile")
# GROQ_MODEL=llama-3.3-70b-versatile

# Fallback models if primary returns 404/model_not_found (comma-separated)
# Try ordering by quality/performance preference.
# Default: "llama-3.1-8b-instant,openai/gpt-oss-20b,qwen/qwen3-32b"
# GROQ_FALLBACK_MODELS=llama-3.1-8b-instant,openai/gpt-oss-20b

# ─── Stripe (for Pro subscription billing) ─────────────────────────────────────

# Your Stripe secret key (server-side only; set in Vercel/Supabase env, NOT VITE_)
STRIPE_SECRET_KEY=<your-stripe-secret-key>

# Stripe webhook signing secret (set in Vercel env for api/stripe-webhook)
STRIPE_WEBHOOK_SECRET=<your-webhook-secret>

# Stripe publishable key (safe in frontend; prefix with VITE_)
VITE_STRIPE_PUBLISHABLE_KEY=<your-publishable-key>

# Primary vision/OCR model (default: "meta-llama/llama-4-scout-17b-16e-instruct")
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Fallback models for vision/OCR (comma-separated)
# Default: "meta-llama/llama-4-scout-17b-16e-instruct,qwen/qwen3-32b"
# GROQ_VISION_FALLBACKS=qwen/qwen3-32b

# CRON secret for keep-alive endpoint (optional)
CRON_SECRET=<your-cron-secret>

# ─── Vite Dev Server-Only (optional) ──────────────────────────────────────────

# Vite dev server port (default: 8080)
VITE_DEV_PORT=8080
